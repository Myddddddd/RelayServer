<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <OutputType>WinExe</OutputType>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <SelfContained>true</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <PublishSingleFile>true</PublishSingleFile>
    <PublishTrimmed>false</PublishTrimmed>
    <!-- Needed for System.Drawing (tray icon) -->
    <UseWindowsForms>true</UseWindowsForms>
    <!-- Require admin for WireGuard tunnel service install -->
    <ApplicationManifest>app.manifest</ApplicationManifest>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting.WindowsServices" Version="8.0.1" />
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="8.0.11" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="wwwroot\**\*" />
  </ItemGroup>

  <!-- Exclude publish output folders from project content -->
  <ItemGroup>
    <Content Remove="publish\**" />
    <Content Remove="publish2\**" />
    <Content Remove="publish3\**" />
    <Content Remove="release\**" />
    <None Remove="publish\**" />
    <None Remove="publish2\**" />
    <None Remove="publish3\**" />
    <None Remove="release\**" />
  </ItemGroup>
</Project>
