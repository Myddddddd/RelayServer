[Unit]
Description=WireGuard Dashboard API
After=network.target wg-quick@wg0.service
Wants=wg-quick@wg0.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/wg-dashboard
Environment="ADMIN_TOKEN=changeme-admin-token"
Environment="SERVER_IP=103.126.161.38"
ExecStart=/opt/wg-dashboard/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
